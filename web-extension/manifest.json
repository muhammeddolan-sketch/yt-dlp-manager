{
  "manifest_version": 3,
  "name": "YT-DLM Web Helper",
  "version": "1.0",
  "description": "IDM-style download button for YT-DLM",
  "permissions": ["activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "host_permissions": ["http://localhost:3000/*"],
  "browser_specific_settings": {
    "gecko": {
      "id": "yt-dlm-downloader@slawn.local",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
